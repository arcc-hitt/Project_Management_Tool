{
  "name": "project-management-backend",
  "version": "1.0.0",
  "description": "Backend API for Project Management Tool",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "jest --watch",
    "migrate": "tsx src/scripts/migrate.ts",
    "seed": "tsx src/scripts/seed.ts",
    "docs": "swagger-jsdoc -d swagger.config.js src/routes/*.ts -o docs/swagger.json"
  },
  "keywords": [
    "project-management",
    "nodejs",
    "express",
    "mongodb",
    "jwt",
    "rest-api"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.2",
    "@types/swagger-ui-express": "^4.1.8",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.2",
    "tsx": "^4.20.5",
    "typescript": "^6.0.2"
  },
  "jest": {
    "projects": [
      {
        "displayName": "integration",
        "testEnvironment": "node",
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "useESM": true,
              "tsconfig": {
                "module": "NodeNext",
                "moduleResolution": "NodeNext",
                "target": "ES2022",
                "esModuleInterop": true,
                "resolveJsonModule": true,
                "strict": false,
                "noImplicitAny": false,
                "skipLibCheck": true
              }
            }
          ]
        },
        "extensionsToTreatAsEsm": [
          ".ts"
        ],
        "moduleNameMapper": {
          "^(\\.{1,2}/.*)\\.js$": "$1"
        },
        "setupFilesAfterEnv": [
          "<rootDir>/tests/setup.mjs"
        ],
        "testMatch": [
          "**/tests/**/*.test.mjs"
        ]
      },
      {
        "displayName": "properties",
        "testEnvironment": "node",
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "useESM": true,
              "tsconfig": {
                "module": "NodeNext",
                "moduleResolution": "NodeNext",
                "target": "ES2022",
                "esModuleInterop": true,
                "resolveJsonModule": true,
                "strict": false,
                "noImplicitAny": false,
                "skipLibCheck": true
              }
            }
          ]
        },
        "extensionsToTreatAsEsm": [
          ".ts"
        ],
        "moduleNameMapper": {
          "^(\\.{1,2}/.*)\\.js$": "$1"
        },
        "testMatch": [
          "**/tests/properties/**/*.test.ts"
        ]
      }
    ]
  }
}
